{
    "name": "chis/laravel-modules",
    "description": "Laravel Modules",
    "type": "library",
    "license": "MIT",
    "autoload": {
        "psr-4": {
            "ChIS\\Modules\\": "src/"
        }
    },
    "require": {
        "php": "^8.5"
    },
    "extra": {
        "laravel": {
            "providers": [
                "ChIS\\Modules\\Providers\\ModuleServiceProvider"
            ]
        }
    },
    "minimum-stability": "dev",
    "prefer-stable": true
}